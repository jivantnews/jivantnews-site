---
import Base from '../../../layouts/Base.astro';
import CategoryNav from '../../../components/CategoryNav.astro';
import NewsRow from '../../../components/NewsRow.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { getPostsByCategory, paginate } from '../../../lib/posts';
import { categories, labelFor, SITE, PAGE_SIZE } from '../../../config';

export async function getStaticPaths() {
  const paths = [];
  for (const c of categories) {
    const posts = await getPostsByCategory(c.slug);
    const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
    for (let p = 2; p <= totalPages; p++) {
      paths.push({ params: { category: c.slug, page: String(p) } });
    }
  }
  return paths;
}

const { category, page } = Astro.params;
const pageNum = parseInt(page as string, 10);
const posts = await getPostsByCategory(category as string);
const { pageItems, hasNext } = paginate(posts, pageNum);
const label = labelFor(category as string);
---
<Base
  title={`${label} समाचार — पेज ${pageNum} — ${SITE.name}`}
  canonicalPath={`/${category}/page/${pageNum}/`}
>
  <CategoryNav slot="nav" active={category as string} />
  <h1 class="page-title">{label}</h1>
  <div class="list">
    {pageItems.map((post) => (
      <NewsRow
        category={post.data.category}
        slug={post.slug}
        title={post.data.title}
        image={post.data.image}
        imageAlt={post.data.imageAlt}
      />
    ))}
  </div>
  <AdSlot label="Advertisement" />
  <div class="pager">
    <a href={pageNum === 2 ? `/${category}/` : `/${category}/page/${pageNum - 1}/`}>← नई खबरें</a>
    {hasNext && <a href={`/${category}/page/${pageNum + 1}/`}>और पुरानी खबरें →</a>}
  </div>
</Base>

<style>
  .page-title { font-size: 1.4rem; margin-bottom: 16px; }
  .list { display: flex; flex-direction: column; }
  .pager {
    display: flex;
    justify-content: space-between;
    margin-top: 24px;
    font-weight: 700;
    color: var(--marigold);
  }
</style>
