---
import Base from '../layouts/Base.astro';
import CategoryNav from '../components/CategoryNav.astro';
import NewsRow from '../components/NewsRow.astro';
import AdSlot from '../components/AdSlot.astro';
import { getAllPostsSorted, paginate } from '../lib/posts';
import { SITE } from '../config';

const all = await getAllPostsSorted();
const { pageItems, hasNext } = paginate(all, 1);
---
<Base title={`${SITE.name} — ताज़ा हिंदी समाचार`} canonicalPath="/">
  <CategoryNav slot="nav" />
  <div class="list">
    {pageItems.map((post) => (
      <NewsRow
        category={post.data.category}
        slug={post.slug}
        title={post.data.title}
        image={post.data.image}
        imageAlt={post.data.imageAlt}
      />
    ))}
  </div>
  {all.length === 0 && (
    <p class="empty">अभी कोई समाचार नहीं है। <a href="/admin/">/admin</a> पेज से पहला समाचार जोड़ें।</p>
  )}
  <AdSlot label="Advertisement" />
  {hasNext && (
    <a class="view-more" href="/page/2/">और पुरानी खबरें देखें</a>
  )}
</Base>

<style>
  .list { display: flex; flex-direction: column; }
  .empty { color: var(--muted); padding: 40px 0; text-align: center; }
  .view-more {
    display: block;
    text-align: center;
    margin: 24px auto 0;
    padding: 12px 28px;
    background: var(--indigo);
    color: #fff;
    font-weight: 700;
    border-radius: 4px;
    max-width: 260px;
  }
</style>
