---
export interface Props { label?: string; }
const { label = "Advertisement" } = Astro.props;
---
<div class="ad-slot">
  <span>{label}</span>
  <!-- AdSense code goes here once approved -->
</div>

<style>
  .ad-slot {
    margin: 24px auto;
    max-width: 1080px;
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--line);
    border-radius: 4px;
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
</style>
