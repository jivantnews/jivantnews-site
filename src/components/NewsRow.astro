---
import { labelFor } from '../config';
export interface Props {
  category: string;
  slug: string;
  title: string;
  image: string;
  imageAlt?: string;
}
const { category, slug, title, image, imageAlt } = Astro.props;
---
<a class="row" href={`/${category}/${slug}/`}>
  <div class="text">
    <span class="cat">{labelFor(category)}</span>
    <h3 class="headline">{title}</h3>
  </div>
  <div class="thumb">
    <img src={image} alt={imageAlt || title} loading="lazy" />
  </div>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 65% 35%;
    gap: 12px;
    align-items: start;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
  }
  .text { min-width: 0; }
  .cat {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--marigold);
    margin-bottom: 6px;
  }
  h3.headline {
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: var(--chip-bg);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 640px) {
    h3.headline { font-size: 0.92rem; }
  }
</style>
