---
export interface Props { items: string[]; }
const { items } = Astro.props;
const list = items.length ? items : ['जीवंत न्यूज़ में आपका स्वागत है'];
---
<div class="ticker">
  <span class="badge">ताज़ा ख़बर</span>
  <div class="track">
    {list.map((t) => <span>{t}</span>)}
    {list.map((t) => <span>{t}</span>)}
  </div>
</div>

<style>
  .ticker {
    background: #C0392B;
    color: #fff;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
  }
  .ticker .badge {
    position: absolute;
    z-index: 2;
    top: 0; left: 0; bottom: 0;
    background: #1D2951;
    display: flex;
    align-items: center;
    padding: 0 14px;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1px;
    font-family: 'Noto Sans Devanagari', sans-serif;
  }
  .ticker .track {
    display: inline-block;
    padding-left: 160px;
    animation: scroll-left 32s linear infinite;
    font-size: 0.9rem;
    font-weight: 500;
    font-family: 'Noto Sans Devanagari', sans-serif;
  }
  .ticker .track span {
    margin-right: 48px;
    color: #fff;
    text-decoration: none;
  }
  @keyframes scroll-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker .track { animation: none; }
  }
</style>
